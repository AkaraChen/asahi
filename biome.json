{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "apps/**",
      ".github/workflows/**",
      "package.json",
      "biome.json",
      "pnpm-workspace.yaml",
      "!**/node_modules",
      "!**/.next",
      "!**/.turbo",
      "!**/.vite",
      "!**/dist",
      "!**/out",
      "!**/.vercel",
      "!**/coverage",
      "!**/*.tsbuildinfo",
      "!apps/app/src/components/githubPrimerMarkdownCss.ts",
      "!pnpm-lock.yaml"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "a11y": {
        "preset": "none"
      },
      "suspicious": {
        "noAssignInExpressions": "off",
        "noDuplicateProperties": "off"
      },
      "style": {
        "useImportType": "off"
      }
    }
  },
  "assist": {
    "enabled": false
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
